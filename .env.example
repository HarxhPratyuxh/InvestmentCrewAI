# --- LLM Configuration ---
# Set a default provider if an agent-specific provider isn't defined
# Options: "openrouter", "google", "openai", "groq"
DEFAULT_LLM_PROVIDER="google"

# --- Per-Agent Configuration (Optional) ---
# Format: {AGENT_ROLE}_PROVIDER and {AGENT_ROLE}_MODEL
# 
# This incredibly allows mapping high-throughput free-tier AI endpoints (like Groq) 
# to concurrent researchers, and high-accuracy models (like Gemini/GPT4) to final Analysts.
#
# Examples (Uncomment to use):
# DATA_RESEARCHER_PROVIDER="groq"
# DATA_RESEARCHER_MODEL="groq/groq/compound-mini"
# DATA_ANALYST_PROVIDER="google"
# DATA_ANALYST_MODEL="gemini/gemini-3.1-flash-lite-preview"

# API Keys
#required default
GOOGLE_API_KEY="your_google_api_key"
#optional
OPENROUTER_API_KEY="your_openrouter_api_key"
OPENROUTER_MODEL="openrouter/meta-llama/llama-3.3-70b-instruct"
OPENAI_API_KEY="your_openai_api_key"
GROQ_API_KEY="your_groq_api_key"

# Associated Tools Configuration (required)
EXA_API_KEY="your_exa_api_key_for_news"

# --- CrewAI Settings ---
# Note: Testing=true hides blocking interactive CLI prompts that might crash background threads.
CREWAI_TRACING_ENABLED=true
CREWAI_TESTING=true
CREWAI_TELEMETRY_OPT_OUT=true
